# Snow 环境变量模板
# 复制此文件为 .env.local / packages/web/.env.local 并填入真实值
# ⚠️ 不要把真实密钥提交到 Git

# -----------------------------
# Core / Web 共同运行时依赖
# -----------------------------

# PostgreSQL（Supabase / Postgres）
DATABASE_URL=""

# 主对话模型
DEEPSEEK_API_KEY=""

# Embedding 模型
OPENROUTER_API_KEY=""

# Supabase（Web Auth + SSR）
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Upstash Redis（热数据 / 缓存 / 调度状态）
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Upstash QStash（延时任务创建）
QSTASH_TOKEN=""

# QStash 回调验签
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# QStash 回调的目标地址
# 本地联调时可填写 tunnel 地址
# 线上部署时必须改为真实公网地址，例如：
# https://your-domain.com/api/tasks/idle
SNOW_IDLE_TASK_URL=""

# -----------------------------
# 非当前运行时必需（可不配）
# -----------------------------

# 当前代码未直接使用，仅保留给手动排查 / 外部工具
QSTASH_URL=""
DIRECT_URL=""
