# Snow 环境变量模板
# 复制此文件为 .env.local 并填入真实值
# ⚠️ 不要把 .env.local 提交到 Git！

# DeepSeek（主力对话模型）
DEEPSEEK_API_KEY=""

# OpenRouter（Embedding 模型：text-embedding-3-small）
OPENROUTER_API_KEY=""

# Supabase（数据库 + Auth + Realtime）
DATABASE_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Upstash Redis（缓存）
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Upstash QStash（异步任务队列）
QSTASH_URL=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
